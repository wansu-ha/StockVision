# docker-compose.yml에서 참조하는 환경변수 템플릿
# 사용: cp .env.example .env && (필요 시) 값 수정

# === PostgreSQL (docker-compose.yml: postgres + cloud_server) ===
POSTGRES_DB=stockvision
POSTGRES_USER=stockvision_user
POSTGRES_PASSWORD=stockvision_pass

# === 클라우드 서버 (docker-compose.yml: cloud_server) ===
CORS_ORIGINS=http://localhost:5173
